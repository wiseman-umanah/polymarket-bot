# ── Required ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=        # From @BotFather
ADMIN_CHAT_ID=             # Your Telegram numeric ID (from @userinfobot)

# ── Database ──────────────────────────────────────────────────────────────────
# Leave DATABASE_URL empty to use SQLite locally.
# Railway injects this automatically when you add a PostgreSQL plugin.
DATABASE_URL=
SQLITE_PATH=polymarket.db
DB_PRUNE_DAYS=7

# ── Market filtering ──────────────────────────────────────────────────────────
MIN_VOLUME=10000
MIN_VOLUME_24HR=1000
MARKET_FETCH_LIMIT=100

# ── Polling ───────────────────────────────────────────────────────────────────
POLL_INTERVAL=30

# ── Signal detection ──────────────────────────────────────────────────────────
PRICE_CHANGE_THRESHOLD=0.04
VOLUME_SPIKE_MULTIPLIER=2.0
VOLUME_AVERAGE_WINDOW=10
LOOKBACK_MINUTES=5
ALERT_COOLDOWN_MINUTES=15

# ── Server (Railway / webhook) ────────────────────────────────────────────────
# Leave WEBHOOK_URL empty locally — bot will use polling mode.
# Set it to your Railway public domain after deploying.
WEBHOOK_URL=
PORT=8443
HEALTH_PORT=8080
WEBHOOK_SECRET=
