# ── Required ───────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Market Filtering ───────────────────────────────────────────────────────
MIN_VOLUME=10000          # Minimum total volume (USD) to watch a market
MIN_VOLUME_24HR=1000      # Minimum 24h volume (USD)
MARKET_FETCH_LIMIT=100    # Number of markets fetched per poll cycle

# ── Signal Detection ───────────────────────────────────────────────────────
PRICE_CHANGE_THRESHOLD=0.04   # 4% price move triggers an alert
VOLUME_SPIKE_MULTIPLIER=2.0   # 2x average volume triggers an alert
VOLUME_AVERAGE_WINDOW=10      # Snapshots used to compute volume average
LOOKBACK_MINUTES=5            # Price comparison window (minutes)

# ── Bot Behaviour ──────────────────────────────────────────────────────────
POLL_INTERVAL=30              # Seconds between market polls
ALERT_COOLDOWN_MINUTES=15     # Minimum minutes between alerts per market/signal

# ── Database ───────────────────────────────────────────────────────────────
DB_PRUNE_DAYS=7               # Delete snapshots older than this many days
